{
  "name": "contactus-internal",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/contactus/internal/src",
  "prefix": "sneat",
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/libs/contactus/internal"],
      "options": {
        "project": "libs/contactus/internal/ng-package.json",
        "tsConfig": "libs/contactus/internal/tsconfig.lib.json"
      },
      "configurations": {
        "production": { "tsConfig": "libs/contactus/internal/tsconfig.lib.prod.json" },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/libs/contactus/internal"],
      "options": { "tsConfig": "libs/contactus/internal/tsconfig.spec.json" }
    },
    "lint": { "executor": "@nx/eslint:lint" }
  }
}
